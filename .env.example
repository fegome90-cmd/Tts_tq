# TTS Lab environment configuration.
# Copy to `.env` and fill in real values. Never commit a real API key.

# --- Provider selection -------------------------------------------------
# Active TTS provider. "qwen" (default, local model) or "inworld" (cloud).
TTS_PROVIDER=qwen

# --- Qwen (local) -------------------------------------------------------
TTS_MODEL_PATH=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
TTS_DEVICE=mps
TTS_OUTPUT_DIR=output
TTS_VOICES_DIR=voice_profiles

# --- Inworld (cloud, experimental — not yet validated E2E) -------------
# Required when TTS_PROVIDER=inworld. Base64-encoded "keyId:keySecret".
INWORLD_API_KEY=
INWORLD_BASE_URL=https://api.inworld.ai
# Preset voice used when a generate request carries no --speaker.
INWORLD_DEFAULT_VOICE_ID=Sarah
# Audio encoding for Inworld responses. "LINEAR16" (WAV-friendly) or "MP3".
INWORLD_AUDIO_ENCODING=LINEAR16
# Per-request HTTP timeout (seconds) for the Inworld TTS API call.
INWORLD_HTTP_TIMEOUT=30
